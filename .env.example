# --- AWS credentials (used by the aws CLI inside the container) ---
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=eu-central-1

# --- Target bucket ---
COLDVAULT_BUCKET=my-deep-archive-bucket
# Optional global key prefix, e.g. "archive" -> archive/<label>/<path>
COLDVAULT_PREFIX=
COLDVAULT_STORAGE_CLASS=DEEP_ARCHIVE

# --- USB / canary watcher ---
# Comma-separated roots scanned for mounted drives (Debian automount: /media)
COLDVAULT_WATCH_DIRS=/media
# File that must exist in the root of a drive to trigger auto-upload.
# Empty file -> label = volume folder name.
# Or put a plain-text name, or JSON: {"name": "movie-drive-01", "prefix": "raw"}
COLDVAULT_CANARY=coldvault.canary
COLDVAULT_AUTO_UPLOAD=true
COLDVAULT_WATCH_INTERVAL=10

# --- Uploads ---
COLDVAULT_UPLOAD_WORKERS=2
# Content-based duplicate detection: skip a file if an object with identical
# SHA-256 + size is already verified in the same bucket (even under another
# key/label). Costs one extra read pass to hash files larger than the
# multipart threshold before uploading; set false to disable.
COLDVAULT_DEDUPE=true
# Files bigger than this use s3api multipart upload with parallel parts.
# A single put-object stream tops out around 20-40 MB/s; multipart uploads
# PART_WORKERS parts at once, multiplying per-file throughput.
COLDVAULT_MULTIPART_THRESHOLD_MB=512
COLDVAULT_PART_SIZE_MB=256
# Parallel upload-part calls per file. Temp disk needed in data/tmp:
# PART_SIZE_MB x PART_WORKERS x UPLOAD_WORKERS (defaults: ~2 GB)
COLDVAULT_PART_WORKERS=4
# Extra roots allowed for manual uploads/browsing (comma-separated).
# Each root must also be bind-mounted into the container in docker-compose.yml.
COLDVAULT_BROWSE_ROOTS=/tank/nextcloud/data/tadek/files

# --- Restores ---
# How often to poll S3 for restore completion
COLDVAULT_RESTORE_POLL_MINUTES=60

# --- Downloads (restored objects -> local disk) ---
# Must be a READ-WRITE volume mount in docker-compose.yml. Downloads are only
# allowed inside this directory.
COLDVAULT_DOWNLOAD_DIR=/downloads
COLDVAULT_DOWNLOAD_WORKERS=2
# Objects larger than the part size are fetched with parallel ranged GETs
COLDVAULT_DOWNLOAD_PART_WORKERS=4
COLDVAULT_DOWNLOAD_PART_SIZE_MB=256

# --- App ---
COLDVAULT_PORT=9999
